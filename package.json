{
  "name": "cashflow-tracker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "pages:dev": "npm run build && wrangler pages dev dist --compatibility-date=2024-09-02",
    "deploy": "npm run build && wrangler pages deploy dist",
    "db:create": "wrangler d1 create cashflow-tracker-db",
    "db:migrate:local": "wrangler d1 execute cashflow-tracker-db --local --file=migrations/0001_initial.sql",
    "db:migrate:remote": "wrangler d1 execute cashflow-tracker-db --file=migrations/0001_initial.sql",
    "db:seed:local": "wrangler d1 execute cashflow-tracker-db --local --file=migrations/0002_seed.sql",
    "cf:types": "wrangler types"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.441.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.5.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.11",
    "typescript": "^5.5.3",
    "vite": "^5.4.3",
    "wrangler": "^3.75.0"
  }
}
