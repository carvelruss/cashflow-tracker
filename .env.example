# Copy this to .dev.vars for local Cloudflare Pages development
# These are the environment variables / secrets used by the application

# Required: Secret key for signing JWT tokens (min 32 chars, use a strong random value)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Optional: Key required to access the /api/auth/setup endpoint (first-time user creation)
# If not set, anyone can create the first user account
SETUP_KEY=your-optional-setup-key

# D1 Database binding is configured in wrangler.toml
# DB binding is automatically available in Cloudflare Pages Functions
